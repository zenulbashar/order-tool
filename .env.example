# Neon Postgres connection (project hosted in ap-southeast-2 / Sydney).
# App runtime: use the POOLED connection string (host contains "-pooler").
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.ap-southeast-2.aws.neon.tech/order_tool?sslmode=require"

# Auth.js session secret — generate with: openssl rand -base64 33
AUTH_SECRET=""

# Resend (magic-link delivery). Used for BOTH owner sign-in (Auth.js) AND the
# opt-in customer sign-in (#7, lib/customer/email.ts) — the customer flow reuses
# these SAME credentials via the Resend REST API, so #7 adds NO new env.
RESEND_API_KEY=""
# Sender identity. MUST be a Resend-verified sending domain or sends will fail.
# Uses the main product domain (prompt2eat.com) — verify it in Resend first.
EMAIL_FROM="Prompt2Eat <noreply@prompt2eat.com>"

# Twilio (customer order SMS — "order confirmed" / "order ready"). ALL THREE are
# required to send; when any is unset, SMS notifications are a silent no-op and
# order emails still go out (lib/sms.ts). TWILIO_FROM is a sending number in
# E.164 (e.g. "+61…") OR a Messaging Service SID ("MG…").
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# WhatsApp order notifications (Twilio WhatsApp — same account as the SMS vars
# above). The text channel PREFERS WhatsApp when these are set and falls back to
# SMS otherwise. Business-initiated messages need Meta-approved templates, so set
# a Content SID per event. TWILIO_WHATSAPP_FROM is "whatsapp:+61…" (or a bare
# "+61…") or an "MG…" Messaging Service SID. Templates take positional vars:
# {{1}} first name, {{2}} venue, {{3}} order reference, {{4}} order URL.
TWILIO_WHATSAPP_FROM=""
TWILIO_WHATSAPP_CONFIRMED_SID=""
TWILIO_WHATSAPP_READY_SID=""

# Set AUTH_URL to the MAIN domain (prompt2eat.com) in production so magic-link
# sign-in links and callbacks use it instead of the *.vercel.app preview URL (or
# a secondary domain). Also used to build Stripe Connect onboarding return URLs:
# AUTH_URL="https://prompt2eat.com"

# Stripe (TEST mode). Connect Express direct charges on each venue's own
# account; the platform takes a per-order application fee.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Generated when you register the webhook endpoint in the Stripe Dashboard
# (a post-deploy step — see README). The webhook route REJECTS requests when
# this is unset; it never bypasses signature verification.
STRIPE_WEBHOOK_SECRET="whsec_..."
# SEPARATE signing secret for the platform BILLING webhook
# (/api/stripe/billing-webhook), which handles subscription/invoice/checkout
# events for venue plans. Distinct endpoint, distinct secret — never share it
# with STRIPE_WEBHOOK_SECRET above (that one is the diner/order webhook). The
# billing route REJECTS requests when this is unset.
STRIPE_BILLING_WEBHOOK_SECRET="whsec_..."

# Anthropic (vision) — powers the owner-only "Import menu from photo" flow.
# Lazy-init (lib/anthropic.ts), so build/typecheck run without it. Each import
# is a metered API cost (a few cents to ~tens of cents per menu).
ANTHROPIC_API_KEY=""

# Cloudflare R2 (S3-compatible) — stores owner-uploaded menu-item photos.
# Lazy-init (lib/r2.ts), so build/typecheck/lint run without these; they are
# only needed at runtime to actually upload/serve photos. Uploads are
# server-side (never browser->R2). Create an R2 bucket, enable public access
# (or attach a Cloudflare custom domain), and an R2 API token (Account ID +
# Access Key + Secret). NEVER commit real values.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="order-tool-photos"
# Public base URL photos are served from — the public R2 bucket URL
# (https://pub-xxxx.r2.dev) or a Cloudflare-proxied custom domain
# (https://images.zaleit.com.au). No trailing slash needed. Stored verbatim
# (with the object key appended) in menu_items.image_url.
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Upstash Redis (REST) — shared store for application-level rate limiting.
# Serverless functions don't share memory, so an in-memory counter can't
# rate-limit; the limiter (lib/rate-limit.ts) needs this shared store. Lazy-init,
# so build/typecheck/lint run without these. When ABSENT the limiter FAILS OPEN
# (no limiting) — fine for dev/preview; set them in prod for limits to apply.
# Create a database at upstash.com and copy its REST URL + token. NEVER commit
# real values.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# AI support chat — the Foundry agents service (docs/ai-support-contract.md).
# All lazy-read: build/typecheck/lint run without these.
# SUPPORT_API_URL: base URL of Foundry's support API (no trailing slash).
#   Unset ⇒ the support widget shows "support is offline".
#   The literal value "mock" serves a built-in mock stream (dev/preview).
SUPPORT_API_URL=""
# Ed25519 PRIVATE key (base64 of a PKCS8 PEM) used to mint the per-request
# identity token; Foundry pins only the PUBLIC key. Generate:
#   openssl genpkey -algorithm ed25519 -out support-sso.pem
#   base64 -w0 support-sso.pem   # -> SUPPORT_SSO_PRIVATE_KEY
#   openssl pkey -in support-sso.pem -pubout   # -> give this to Foundry
SUPPORT_SSO_PRIVATE_KEY=""
# Shared secret HMAC-signing OUR request bodies to Foundry (contract §2.2).
SUPPORT_API_SECRET=""
# Shared secret verifying Foundry's INBOUND ticket webhooks (contract §5).
# Absent ⇒ /api/support/webhook fail-safes to 503.
SUPPORT_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# SEO & measurement
# ---------------------------------------------------------------------------
# Canonical public origin used for metadata/canonical/OG/sitemap URLs
# (lib/seo.ts). Defaults to https://prompt2eat.com when unset; set it on
# previews so canonical URLs stay honest there.
NEXT_PUBLIC_SITE_URL=""
# Comma-separated hosts that serve the MARKETING landing at "/" (app/page.tsx).
# Unset ⇒ prompt2eat.com. Other hosts redirect "/" to sign-in / dashboard.
MARKETING_HOSTS=""
# Google Search Console ownership proof (HTML-tag method): paste ONLY the
# content="..." value from Search Console → Settings → Ownership verification.
# When set, app/layout.tsx emits the <meta name="google-site-verification">
# tag; then verify the property and submit /sitemap.xml in Search Console.
GOOGLE_SITE_VERIFICATION=""
# Google Analytics 4 measurement id ("G-…"). The gtag snippet renders only
# when set (app/_components/analytics.tsx) — dev/preview stay untracked.
NEXT_PUBLIC_GA_ID=""
# Search Console → SEO & AEO studio stats ingest (lib/search-console.ts +
# /api/jobs/seo-stats). Create a Google Cloud service account, enable the
# "Google Search Console API", add the service account's email to the
# prompt2eat.com property as a RESTRICTED user in Search Console, then set:
# its client_email, its PEM private key ("\n" escapes tolerated), and the
# property EXACTLY as registered ("sc-domain:prompt2eat.com" or
# "https://prompt2eat.com/"). Absent ⇒ the cron no-ops and the owner
# dashboard shows its "not connected" state. NEVER commit real values.
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""
GSC_SITE_URL=""
# Vercel Cron auth for /api/jobs/* (integrations + seo-stats). Vercel sends
# "Authorization: Bearer <CRON_SECRET>"; the routes refuse when it is unset.
CRON_SECRET=""
